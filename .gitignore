# ==========================================
# Frostella Backend .gitignore
# ==========================================

# 1. Maven build outputs
target/
*.jar
*.war
*.ear
*.zip
*.tar.gz
*.rar

# 2. IDE / Environment
.idea/
.vscode/
*.iml
.project
.classpath
.settings/
.springBeans

# 3. Logs and temp files
*.log
logs/
*.tmp
*.bak
*.swp
*~.nib

# 4. OS files
.DS_Store
Thumbs.db

# 5. Environment configuration (NEVER COMMIT SECRETS)
.env
.env.*
application-dev.properties
application-prod.properties

# 6. Maven Wrapper
.mvn/wrapper/maven-wrapper.jar

# 7. Additional IDE/System
.nbproject/
.factorypath
bin/
lib/
